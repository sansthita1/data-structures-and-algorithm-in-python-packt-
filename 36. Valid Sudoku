class Solution:
    def isValidSudoku(self, board: List[List[str]]) -> bool:
        row = [set() for _ in range(9)]
        col = [set() for _ in range(9)]
        grid = [set() for _ in range(9)]
        
        for i in range(9):
            for j in range(9):
                if (board[i][j] == "."):
                    continue
                
                gridno = (i//3)*3 + (j//3)
                isrowpresent = board[i][j] in row[i]
                iscolpresent = board[i][j] in col[j]
                isgridpresent = board[i][j] in grid[gridno]
                
                if (isrowpresent or iscolpresent or isgridpresent):
                    return False
                
                
                row[i].add(board[i][j])
                col[j].add(board[i][j])
                grid[gridno].add(board[i][j])
                
        return True
