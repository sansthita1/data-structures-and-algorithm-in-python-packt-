class Solution:
    def rotate(self, nums: List[int], k: int) -> None:
        n = len(nums)
        self.reverse(nums, 0 , n-1)
        self.reverse(nums, 0, k-1)
        self.reverse(nums, k, n-1)
        k = k%n

    def reverse(self, nums, start, end):
        i = start
        j = end
        while (i <j):
            nums[i],nums[j] = nums[j], nums[i]
            
            i+=1
            j-=1
        
        
