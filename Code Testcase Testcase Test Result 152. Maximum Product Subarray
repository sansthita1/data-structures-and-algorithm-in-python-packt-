class Solution:
    def maxProduct(self, nums: List[int]) -> int:
        result = nums[0]
        maxp= nums[0]
        minp= nums[0]
        for i in range(1, len(nums)):
            if nums[i]>=0:
                maxp = max(maxp*nums[i], nums[i])
                minp= min(minp*nums[i], nums[i])
            else:
                temp = maxp
                maxp= max(minp*nums[i], nums[i])
                minp= min(temp*nums[i], nums[i])
            result = max(result, maxp)
        return result
